# 智谱 AI API Key
VITE_ZHIPU_API_KEY=your_api_key_here

# API 端点（可选）
VITE_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 后端 API 地址（开发环境走 Vite 代理，Vercel 生产环境自动设为 /api）
VITE_API_BASE=/api

# JWT 密钥（Vercel 生产环境请在 Dashboard → Settings → Environment Variables 中设置）
JWT_SECRET=your-jwt-secret

# Vercel Postgres（自动注入，无需手动设置）
# 在 Vercel Dashboard → Storage → Create Database → Postgres
# 创建后以下变量会自动注入：
# POSTGRES_URL
# POSTGRES_PRISMA_URL
# POSTGRES_URL_NON_POOLING
# POSTGRES_USER
# POSTGRES_HOST
# POSTGRES_PASSWORD
# POSTGRES_DATABASE

# 以下仅本地开发使用（连接本地 MySQL）
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=ai_chat
